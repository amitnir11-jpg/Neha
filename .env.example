NODE_ENV=production
PORT=3001
HOST=0.0.0.0
MOBILE_DISCOVERY_PORT=3001

# Local PC MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/daksh_inventory_v2

# Online MongoDB Atlas:
MONGO_URI=mongodb+srv://dakshstockyard:<db_password>@cluster0.qerfydz.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=daksh_inventory_v2
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=15000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_MAX_POOL_SIZE=20
# Optional: helps Node resolve Atlas SRV records on networks that refuse local SRV DNS lookups.
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
# Optional for the Windows PC app: if Atlas blocks this PC IP, continue using local MongoDB.
MONGO_AUTO_LOCAL_FALLBACK=true
MONGO_FALLBACK_URI=mongodb://127.0.0.1:27017/daksh_inventory_v2
# When local fallback is active, keep checking Atlas and promote back after local data is copied.
MONGO_AUTO_PROMOTE_TO_ATLAS=true
MONGO_PRIMARY_RETRY_MS=30000
MONGO_CLOUD_SYNC_BATCH_SIZE=500

JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_BASE_URL=https://your-daksh-inventory.up.railway.app

# Optional email/OTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL=amitsvision4u@gmail.com
